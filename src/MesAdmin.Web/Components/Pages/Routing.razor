    // ═══════════════════════════════════════════
    // 新建工艺路线
    // ═══════════════════════════════════════════

    private async Task PrepareCreateAsync()
    {
        _activeTab = 1; // 切换到新建标签页
        _isLoadingDefault = true;
        _newRouting.Clear();
        _newRouting.ProductCode = "ESP-9.0";
        try
        {
            _defaultRouting = await GetDefaultFallback();
        }
        catch
        {
            _defaultRouting = await GetDefaultFallback();
        }
        finally
        {
            _isLoadingDefault = false;
        }
    }

    private async Task<RoutingResponseDto?> GetDefaultFallback()
    {
        try
        {
            var d = await Api.GetAsync<RoutingResponseDto>("api/v1/routing/ESP-9.0/default");
            return d;
        }
        catch
        {
            return null;
        }
    }

    private async Task CreateRoutingAsync()
    {
        if (!IsCreateFormValid) return;
        _isLoading = true;
        _message = null;
        try
        {
            // 从默认模板构建 31 工序
            var defaultOps = _defaultRouting?.Operations
                .Select(o => new CreateRoutingOperationBody(
                    o.Sequence, o.Station, o.OperationCode, o.OperationName,
                    o.StandardTimeSeconds, o.FixtureCode, o.FixtureName,
                    o.ParameterTemplates.Select(pt => new CreateParameterTemplateBody(
                        pt.ParameterCode, pt.ParameterName, pt.StandardValue,
                        pt.UpperSpecLimit, pt.LowerSpecLimit, pt.Unit,
                        pt.EnableSpc, pt.SpcSubgroupSize
                    )).ToList()
                )).ToList() ?? [];

            var body = new CreateRoutingBody(
                _newRouting.ProductCode,
                _newRouting.Name,
                _newRouting.Version,
                _newRouting.CreatedBy,
                string.IsNullOrWhiteSpace(_newRouting.EcoNumber) ? null : _newRouting.EcoNumber,
                string.IsNullOrWhiteSpace(_newRouting.ChangeDescription) ? null : _newRouting.ChangeDescription,
                defaultOps);

            var (ok, data, _) = await Api.CreateRoutingAsync(body);
            if (ok && data is not null)
            {
                _message = $"工艺路线 {data.ProductCode} V{data.Version} 创建成功！";
                _isError = false;
                _newRouting.Clear();
                _newRouting.ProductCode = "ESP-9.0";
                _routings.Add(data);
                ComputeStats();
                ApplyFilters();
                // 回到列表标签页
                _activeTab = 0;
            }
        }
        catch (Exception ex)
        {
            _message = $"创建工艺路线失败：{ex.Message}";
            _isError = true;
        }
        finally
        {
            _isLoading = false;
        }
    }

    // ═══════════════════════════════════════════
    // 辅助方法
    // ═══════════════════════════════════════════

    private void ReplaceRouting(string id, RoutingResponseDto updated)
    {
        var idx = _routings.FindIndex(r => r.Id == id);
        if (idx >= 0) _routings[idx] = updated;
        ApplyFilters();
    }

    private static string GetEcoLabel(string status) => status switch
    {
        "Draft" => "草稿",
        "PendingApproval" => "审批中",
        "Approved" => "已批准",
        "Released" => "已生效",
        "Superseded" => "已取代",
        _ => status
    };

    private static Color GetEcoChipColor(string status) => status switch
    {
        "Draft" => Color.Default,
        "PendingApproval" => Color.Warning,
        "Approved" => Color.Info,
        "Released" => Color.Success,
        "Superseded" => Color.Tertiary,
        _ => Color.Default
    };

