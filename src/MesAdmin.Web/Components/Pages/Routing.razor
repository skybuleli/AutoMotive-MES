    private async Task SubmitEcoAsync(RoutingResponseDto routing)
    {
        _isLoading = true;
        _message = null;
        try
        {
            var (ok, data, _) = await Api.SubmitRoutingAsync(routing.Id);
            if (ok && data is not null)
            {
                ReplaceRouting(routing.Id, data);
                _message = $"工艺路线 {routing.ProductCode} V{routing.Version} 已提交 ECO 审批";
                _isError = false;
                ComputeStats();
            }
        }
        catch (Exception ex)
        {
            _message = $"提交 ECO 审批失败：{ex.Message}";
            _isError = true;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void OpenApproveDialog(RoutingResponseDto routing)
    {
        _selectedRouting = routing;
        _approveBy = string.Empty;
        _showApproveDialog = true;
    }

    private async Task ApproveEcoAsync()
    {
        if (_selectedRouting is null || string.IsNullOrWhiteSpace(_approveBy)) return;
        _isLoading = true;
        try
        {
            var (ok, data, _) = await Api.ApproveRoutingAsync(_selectedRouting.Id, _approveBy);
            if (ok && data is not null)
            {
                _showApproveDialog = false;
                ReplaceRouting(_selectedRouting.Id, data);
                _message = $"工艺路线 {data.ProductCode} V{data.Version} 已审批通过";
                _isError = false;
                ComputeStats();
            }
        }
        catch (Exception ex)
        {
            _message = $"审批失败：{ex.Message}";
            _isError = true;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task ReleaseRoutingAsync(RoutingResponseDto routing)
    {
        _isLoading = true;
        _message = null;
        try
        {
            var (ok, data, _) = await Api.ReleaseRoutingAsync(routing.Id);
            if (ok && data is not null)
            {
                // 重新加载全部（旧版本可能被 Supersede）
                await LoadAllAsync();
                _message = $"工艺路线 {routing.ProductCode} V{routing.Version} 已发布生效";
                _isError = false;
            }
        }
        catch (Exception ex)
        {
            _message = $"发布生效失败：{ex.Message}";
            _isError = true;
        }
        finally
        {
            _isLoading = false;
        }
    }

