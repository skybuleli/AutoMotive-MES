    /// <summary>
    /// 计算追溯标签码（与 GoodsReceipt.Create 逻辑一致）。
    /// 格式：ESP9-YYYYMMDD-NNNN（工单号后4位）
    /// </summary>
    private static string GetLabelCode(OrderSummary order)
    {
        var datePart = (order.CompletedAt ?? order.CreatedAt).ToString("yyyyMMdd");
        var suffix = order.OrderNumber.Length >= 4
            ? order.OrderNumber[^4..]
            : order.OrderNumber;
        return $"ESP9-{datePart}-{suffix}";
    }

    private static string GetOrderCardStyle(bool allOpsDone)
        => allOpsDone
            ? "margin-bottom:12px; border-left:3px solid var(--mud-palette-success);"
            : "margin-bottom:12px; border-left:3px solid var(--mud-palette-warning);";

    private static string GetReviewerDisplay(OrderSummary order)
    {
        // 完工确认无单独 review 字段在 OrderSummary 中，使用 CompletedAt 存在性判断
        return order.CompletedAt is not null ? "质量审核" : "待审核";
    }

