@page "/"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<PageTitle>仪表盘 — AutoMES</PageTitle>

<!-- 页面标题 -->
<MudText Typo="Typo.h4" Style="font-weight:700; color:#CDD6F4; margin-bottom:4px;">
    博世 ESP® 制动系统 MES
</MudText>
<MudText Typo="Typo.body2" Style="color:#9399B2; margin-bottom:28px;">
    汽车安全件 Tier-1 供应商全链路制造执行系统 · 7 站 31 工序
</MudText>

<!-- KPI 卡片 -->
<MudGrid Spacing="3">
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Elevation="0" Class="pa-5 kpi-card" Style="border-top:3px solid #CBA6F7;">
            <MudStack Row="true" AlignItems="AlignItems.Start" Justify="Justify.SpaceBetween">
                <MudStack Spacing="0">
                    <MudText Typo="Typo.caption" Style="color:#9399B2; font-weight:500;">OEE</MudText>
                    <MudText Typo="Typo.h4" Style="font-weight:700; color:#CBA6F7; margin-top:4px;">85.2%</MudText>
                    <MudText Typo="Typo.caption" Style="color:#6C7086;">全局设备综合效率</MudText>
                </MudStack>
                <MudAvatar Color="Color.Primary" Variant="Variant.Filled"
                           Style="background:rgba(203,166,247,0.15); color:#CBA6F7;">
                    <MudIcon Icon="@Icons.Material.Filled.Speed" />
                </MudAvatar>
            </MudStack>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" sm="6" md="3">
        <MudPaper Elevation="0" Class="pa-5 kpi-card" Style="border-top:3px solid #4ADE80;">
            <MudStack Row="true" AlignItems="AlignItems.Start" Justify="Justify.SpaceBetween">
                <MudStack Spacing="0">
                    <MudText Typo="Typo.caption" Style="color:#9399B2; font-weight:500;">合格率</MudText>
                    <MudText Typo="Typo.h4" Style="font-weight:700; color:#4ADE80; margin-top:4px;">97.5%</MudText>
                    <MudText Typo="Typo.caption" Style="color:#6C7086;">一次合格率</MudText>
                </MudStack>
                <MudAvatar Color="Color.Success" Variant="Variant.Filled"
                           Style="background:rgba(74,222,128,0.15); color:#4ADE80;">
                    <MudIcon Icon="@Icons.Material.Filled.Verified" />
                </MudAvatar>
            </MudStack>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" sm="6" md="3">
        <MudPaper Elevation="0" Class="pa-5 kpi-card" Style="border-top:3px solid #FBBF24;">
            <MudStack Row="true" AlignItems="AlignItems.Start" Justify="Justify.SpaceBetween">
                <MudStack Spacing="0">
                    <MudText Typo="Typo.caption" Style="color:#9399B2; font-weight:500;">在产工单</MudText>
                    <MudText Typo="Typo.h4" Style="font-weight:700; color:#FBBF24; margin-top:4px;">12</MudText>
                    <MudText Typo="Typo.caption" Style="color:#6C7086;">进行中工单数</MudText>
                </MudStack>
                <MudAvatar Color="Color.Warning" Variant="Variant.Filled"
                           Style="background:rgba(251,191,36,0.15); color:#FBBF24;">
                    <MudIcon Icon="@Icons.Material.Filled.Assignment" />
                </MudAvatar>
            </MudStack>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" sm="6" md="3">
        <MudPaper Elevation="0" Class="pa-5 kpi-card" Style="border-top:3px solid #EF4444;">
            <MudStack Row="true" AlignItems="AlignItems.Start" Justify="Justify.SpaceBetween">
                <MudStack Spacing="0">
                    <MudText Typo="Typo.caption" Style="color:#9399B2; font-weight:500;">Andon 报警</MudText>
                    <MudText Typo="Typo.h4" Style="font-weight:700; color:#EF4444; margin-top:4px;">3</MudText>
                    <MudText Typo="Typo.caption" Style="color:#6C7086;">未处理报警</MudText>
                </MudStack>
                <MudAvatar Color="Color.Error" Variant="Variant.Filled"
                           Style="background:rgba(239,68,68,0.15); color:#EF4444;">
                    <MudIcon Icon="@Icons.Material.Filled.NotificationImportant" />
                </MudAvatar>
            </MudStack>
        </MudPaper>
    </MudItem>
</MudGrid>

<!-- 快速操作 -->
<MudText Typo="Typo.h6" Style="font-weight:600; color:#CDD6F4; margin:32px 0 16px;">快速操作</MudText>
<MudGrid Spacing="2">
    <MudItem xs="6" sm="3" md="2">
        <MudButton Href="production" Variant="Variant.Outlined"
                   Color="Color.Primary" FullWidth="true"
                   StartIcon="@Icons.Material.Filled.AddCircle"
                   Style="border-color:rgba(203,166,247,0.25); justify-content:flex-start; padding:10px 16px;">新建工单</MudButton>
    </MudItem>
    <MudItem xs="6" sm="3" md="2">
        <MudButton Href="material" Variant="Variant.Outlined"
                   Color="Color.Success" FullWidth="true"
                   StartIcon="@Icons.Material.Filled.QrCodeScanner"
                   Style="border-color:rgba(74,222,128,0.25); justify-content:flex-start; padding:10px 16px;">扫码入库</MudButton>
    </MudItem>
    <MudItem xs="6" sm="3" md="2">
        <MudButton Href="andon" Variant="Variant.Outlined"
                   Color="Color.Error" FullWidth="true"
                   StartIcon="@Icons.Material.Filled.Campaign"
                   Style="border-color:rgba(239,68,68,0.25); justify-content:flex-start; padding:10px 16px;">触发 Andon</MudButton>
    </MudItem>
    <MudItem xs="6" sm="3" md="2">
        <MudButton Href="traceability" Variant="Variant.Outlined"
                   Color="Color.Warning" FullWidth="true"
                   StartIcon="@Icons.Material.Filled.Search"
                   Style="border-color:rgba(251,191,36,0.25); justify-content:flex-start; padding:10px 16px;">追溯查询</MudButton>
    </MudItem>
</MudGrid>
