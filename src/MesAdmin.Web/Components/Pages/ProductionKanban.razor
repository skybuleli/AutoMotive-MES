@page "/production/kanban"
@attribute [StreamRendering]
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using MesAdmin.Web.Services
@inject MesApiClient Api
@inject NavigationManager Navigation

<PageTitle>工单看板 - AutoMES</PageTitle>

<MudStack Spacing="5">
    <MudPaper Elevation="0" Class="mes-toolbar pa-5">
        <MudStack Row Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudStack Spacing="1">
                <MudText Class="section-kicker">PRODUCTION · 工单看板</MudText>
                <MudText Typo="Typo.h5" Style="font-weight:700;">生产工单看板</MudText>
                <MudText Typo="Typo.body2" Class="section-copy">按状态泳道浏览工单流转 · 点击卡片查看详情</MudText>
            </MudStack>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Refresh" OnClick="ReloadAsync">
                刷新
            </MudButton>
        </MudStack>
    </MudPaper>

    @if (!string.IsNullOrWhiteSpace(_loadError))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Dense>@_loadError</MudAlert>
    }

    <MudGrid Spacing="3">
        @foreach (var column in _columns)
        {
            <MudItem xs="12" sm="6" md="4" lg="2">
                <div class="kanban-column">
                    <div class="kanban-column-head">
                        <span class="kanban-col-dot @column.Key"></span>
                        <MudText Typo="Typo.subtitle2" Style="font-weight:600;flex:1;">@column.Label</MudText>
                        <span class="kanban-count">@column.Orders.Count</span>
                    </div>

                    <MudStack Spacing="2" Class="mt-3">
                        @foreach (var order in column.Orders)
                        {
                            <div class="kanban-card" @onclick="() => GoToDetail(order.Id)">
                                <MudText Typo="Typo.body2" Class="kanban-order-no">@order.OrderNumber</MudText>
                                <MudText Typo="Typo.caption" Class="section-copy">@order.ProductCode · @order.BomVersion</MudText>
                                <MudDivider Class="my-2" />
                                <MudStack Row Justify="Justify.SpaceBetween">
                                    <MudText Typo="Typo.caption">计划 <b>@order.PlannedQuantity</b></MudText>
                                    <MudText Typo="Typo.caption">良品 <b>@order.QualifiedQuantity</b></MudText>
                                </MudStack>
                                <MudText Typo="Typo.caption" Class="kpi-sub mt-1">@order.CreatedAt.ToLocalTime().ToString("MM-dd HH:mm")</MudText>
                            </div>
                        }

                        @if (column.Orders.Count == 0)
                        {
                            <MudText Typo="Typo.caption" Align="Align.Center" Class="section-copy py-6">暂无工单</MudText>
                        }
                    </MudStack>
                </div>
            </MudItem>
        }
    </MudGrid>
</MudStack>

@code {
    private List<KanbanColumn> _columns = [];
    private string? _loadError;
    private bool _loadedOnce;

    private static readonly string[] Statuses = ["Created", "Released", "InProgress", "Completed", "Closed"];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _loadedOnce)
            return;

        _loadedOnce = true;

        try
        {
            await LoadAsync();
            StateHasChanged();
        }
        catch (HttpRequestException ex) when (RedirectToLoginOnUnauthorized(ex))
        {
        }
        catch (Exception ex)
        {
            _loadError = $"加载失败：{ex.Message}";
            StateHasChanged();
        }
    }

    private async Task LoadAsync()
    {
        var columns = new List<KanbanColumn>();

        foreach (var (status, label, key) in new[]
        {
            ("Created", "已创建", "created"),
            ("Released", "已放行", "released"),
            ("InProgress", "执行中", "inprogress"),
            ("Completed", "已完工", "completed"),
            ("Closed", "已关闭", "closed"),
        })
        {
            try
            {
                var items = await Api.GetAsync<List<OrderSummary>>($"api/v1/orders?status={status}&page=1&size=50");
                columns.Add(new KanbanColumn(label, key, items ?? []));
            }
            catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.Unauthorized)
            {
                throw;
            }
            catch
            {
                columns.Add(new KanbanColumn(label, key, []));
            }
        }

        _columns = columns;
        _loadError = null;
    }

    private async Task ReloadAsync()
    {
        try
        {
            await LoadAsync();
            StateHasChanged();
        }
        catch (HttpRequestException ex) when (RedirectToLoginOnUnauthorized(ex))
        {
        }
    }

    private void GoToDetail(string id)
        => Navigation.NavigateTo($"/production?orderId={id}");

    private bool RedirectToLoginOnUnauthorized(HttpRequestException ex)
    {
        if (ex.StatusCode != System.Net.HttpStatusCode.Unauthorized)
            return false;

        var returnUrl = Navigation.ToBaseRelativePath(Navigation.Uri);
        Navigation.NavigateTo($"/login?returnUrl={Uri.EscapeDataString(returnUrl)}", forceLoad: true);
        return true;
    }

    private sealed record KanbanColumn(string Label, string Key, List<OrderSummary> Orders);
}
