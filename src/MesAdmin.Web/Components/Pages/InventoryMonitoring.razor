@page "/inventory"
@attribute [StreamRendering]
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@implements IDisposable
@using System.Net.Http.Json
@using MesAdmin.Web.Services
@inject IHttpClientFactory HttpFactory
@inject AuthService Auth

<PageTitle>线边库存监控 - AutoMES</PageTitle>

<MudStack Spacing="3" Class="oee-page">
    <MudPaper Class="oee-toolbar pa-5">
        <MudStack Row Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap" Spacing="2">
            <MudStack Spacing="1">
                <MudText Typo="Typo.overline" Class="section-kicker">T1.13 · Line-Side Inventory</MudText>
                <MudText Typo="Typo.h4">线边库存实时监控</MudText>
                <MudText Typo="Typo.body2" Class="section-copy">每 30 秒自动刷新 · 阈值配置后生效</MudText>
            </MudStack>
            <MudStack Row Spacing="3" AlignItems="AlignItems.Center">
                @if (_data is not null)
                {
                    <MudChip T="string" Color="Color.Error" Size="Size.Small" Variant="Variant.Filled">
                        红色报警 @_data.RedCount
                    </MudChip>
                    <MudChip T="string" Color="Color.Warning" Size="Size.Small" Variant="Variant.Filled">
                        黄色预警 @_data.YellowCount
                    </MudChip>
                    <MudChip T="string" Color="Color.Success" Size="Size.Small" Variant="Variant.Outlined">
                        正常 @(_data.Items.Count - _data.YellowCount - _data.RedCount)
                    </MudChip>
                }
                <MudIconButton Icon="@Icons.Material.Filled.Refresh" Disabled="@_isLoading"
                               OnClick="() => LoadDataAsync()" Size="Size.Small" />
            </MudStack>
        </MudStack>
    </MudPaper>

    @if (_errorMessage is not null)
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Dense>
            @_errorMessage
        </MudAlert>
    }

    @if (_isLoading && _data is null)
    {
        <MudPaper Class="glass-kpi-card pa-8">
            <MudStack AlignItems="AlignItems.Center" Spacing="2">
                <MudProgressCircular Size="Size.Large" Color="Color.Primary" />
                <MudText Typo="Typo.body2" Class="section-copy">加载库存数据...</MudText>
            </MudStack>
        </MudPaper>
    }
    else if (_data is not null && _data.Items.Count == 0)
    {
        <MudPaper Class="glass-kpi-card pa-8">
            <MudStack AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.Inventory2" Size="Size.Large" Color="Color.Primary" />
                <MudText Typo="Typo.body1">暂无库存监控数据</MudText>
                <MudText Typo="Typo.body2" Class="section-copy">请先在系统中配置物料库存阈值，启用后本页面将自动显示各物料当前库存状态。</MudText>
            </MudStack>
        </MudPaper>
    }
    else if (_data is not null)
    {
        <div class="inventory-grid">
            @foreach (var item in _data.Items)
            {
                var alertColor = item.AlertLevel switch
                {
                    "Red" => "var(--mud-palette-error, #ef4444)",
                    "Yellow" => "var(--mud-palette-warning, #fbbf24)",
                    _ => "var(--mud-palette-success, #4ade80)"
                };

                var isRed = item.AlertLevel == "Red";
                var isYellow = item.AlertLevel == "Yellow";

                <MudPaper Class="@($"glass-kpi-card {(isRed ? "andon-pulse" : "")}")">
                    <MudStack Spacing="2">
                        <MudStack Row Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                            <MudStack Row Spacing="1" AlignItems="AlignItems.Center">
                                <span class="status-dot" style="background: @alertColor; box-shadow: 0 0 8px @alertColor;"></span>
                                <MudText Typo="Typo.subtitle1" Style="font-weight:600;">
                                    @item.MaterialCode
                                    @if (item.IsCritical)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Outlined">关键</MudChip>
                                    }
                                </MudText>
                            </MudStack>
                            <MudChip T="string" Color="@(isRed ? Color.Error : isYellow ? Color.Warning : Color.Success)"
                                     Size="Size.Small" Variant="Variant.Outlined">
                                @item.AlertLevel
                            </MudChip>
                        </MudStack>

                        <MudText Typo="Typo.body2">@item.MaterialName</MudText>

                        <MudStack Row Spacing="4" Justify="Justify.SpaceBetween">
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.caption" Class="kpi-label">当前库存</MudText>
                                <MudText Typo="Typo.h4" Style="@($"color:{alertColor};font-weight:600")">
                                    @item.CurrentQuantity.ToString("F0")
                                    <MudText Typo="Typo.caption" Style="display:inline; color: #9399B2;">@item.Unit</MudText>
                                </MudText>
                            </MudStack>
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.caption" Class="kpi-label">安全库存</MudText>
                                <MudText Typo="Typo.body2">
                                    @item.SafetyStock.ToString("F0") @item.Unit
                                </MudText>
                            </MudStack>
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.caption" Class="kpi-label">最低库存</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Error">
                                    @item.MinimumStock.ToString("F0") @item.Unit
                                </MudText>
                            </MudStack>
                        </MudStack>

                        <MudStack Row Spacing="1" AlignItems="AlignItems.Center">
                            <MudText Typo="Typo.caption" Class="kpi-sub">工位：@item.StationId</MudText>
                            <MudText Typo="Typo.caption" Class="kpi-sub">|</MudText>
                            <MudText Typo="Typo.caption" Class="kpi-sub">
                                阈值利用率：@(item.SafetyStock > 0 ? (item.CurrentQuantity / item.SafetyStock).ToString("P0") : "N/A")
                            </MudText>
                        </MudStack>

                        @* 库存条 *@
                        <MudProgressLinear Value="@GetProgressPercent(item)" Color="@(isRed ? Color.Error : isYellow ? Color.Warning : Color.Success)"
                                           Class="rounded-lg" Style="height: 6px;" />
                    </MudStack>
                </MudPaper>
            }
        </div>

        @* 自动刷新倒计时 *@
        <MudText Typo="Typo.caption" Class="section-copy" Style="text-align:center;">
            下次刷新：@(_countdown)s · @_data.Items.Count 种物料
        </MudText>
    }
</MudStack>

@code {
    private InventoryMonitorData? _data;
    private bool _isLoading;
    private string? _errorMessage;
    private int _countdown;
    private Timer? _timer;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
        _countdown = 30;

        _timer = new Timer(async _ =>
        {
            _countdown--;
            if (_countdown <= 0)
            {
                _countdown = 30;
                await LoadDataAsync();
            }
            await InvokeAsync(StateHasChanged);
        }, null, 1000, 1000);
    }

    private async Task LoadDataAsync()
    {
        _isLoading = true;
        _errorMessage = null;
        try
        {
            var token = await Auth.GetTokenAsync();
            var client = HttpFactory.CreateClient("MesApi");
            if (token is not null)
                client.DefaultRequestHeaders.Authorization =
                    new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

            _data = await client.GetFromJsonAsync<InventoryMonitorData>("api/v1/inventory/monitoring");
        }
        catch (Exception ex)
        {
            _errorMessage = $"加载库存数据失败：{ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private static double GetProgressPercent(InventoryItemStatusDto item)
    {
        if (item.SafetyStock <= 0) return 0;
        var pct = item.CurrentQuantity / item.SafetyStock * 100;
        return Math.Clamp(pct, 0, 100);
    }

    public void Dispose()
    {
        _timer?.Dispose();
    }

    // ── API 响应 DTO ──

    public record InventoryMonitorData(
        List<InventoryItemStatusDto> Items,
        int TotalAlerts,
        int RedCount,
        int YellowCount);

    public record InventoryItemStatusDto(
        string MaterialCode,
        string MaterialName,
        string StationId,
        double CurrentQuantity,
        double SafetyStock,
        double MinimumStock,
        string Unit,
        string AlertLevel,
        bool HasActiveAlert,
        bool IsCritical);
}
