@page "/login"
@attribute [StreamRendering]
@using MesAdmin.Web.Services
@inject AuthService Auth
@inject NavigationManager Navigation

<PageTitle>登录 - AutoMES</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="d-flex align-center justify-center" Style="min-height: 80vh;">
    <MudPaper Elevation="4" Class="pa-8 rounded-xl" Style="width: 100%; max-width: 420px;">
        <MudStack Spacing="4" AlignItems="AlignItems.Center">
            <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Size="Size.Large">
                <MudIcon Icon="@Icons.Material.Filled.PrecisionManufacturing" />
            </MudAvatar>

            <MudText Typo="Typo.h5">AutoMES 登录</MudText>
            <MudText Typo="Typo.body2" Class="text-secondary">
                ESP 总成工厂 · 制造执行中台
            </MudText>

            <MudTextField @bind-Value="_username"
                          Label="用户名"
                          Variant="Variant.Outlined"
                          FullWidth
                          Immediate
                          Margin="Margin.Dense"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Person" />

            <MudTextField @bind-Value="_password"
                          Label="密码"
                          Variant="Variant.Outlined"
                          FullWidth
                          Immediate
                          Margin="Margin.Dense"
                          InputType="InputType.Password"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Lock"
                          OnKeyDown="OnKeyDown" />

            @if (!string.IsNullOrWhiteSpace(_error))
            {
                <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Dense FullWidth>
                    @_error
                </MudAlert>
            }

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Size="Size.Large"
                       FullWidth
                       Disabled="_busy"
                       OnClick="LoginAsync">
                @if (_busy)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate Class="mr-2" />
                    <span>登录中…</span>
                }
                else
                {
                    <span>登录</span>
                }
            </MudButton>

            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense FullWidth>
                演示账号：manager / leader / qe / ee / warehouse / sqe（密码任意）
            </MudAlert>
        </MudStack>
    </MudPaper>
</MudContainer>

@code {
    private string _username = string.Empty;
    private string _password = string.Empty;
    private string _error = string.Empty;
    private bool _busy;

    private async Task LoginAsync()
    {
        _busy = true;
        _error = string.Empty;

        try
        {
            var ok = await Auth.LoginAsync(_username, _password);
            if (ok)
            {
                // 解析 returnUrl 查询参数，无效时回首页
                var uri = Navigation.ToBaseRelativePath(Navigation.Uri);
                var target = "/";
                var queryIndex = uri.IndexOf('?');
                if (queryIndex >= 0)
                {
                    var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Substring(queryIndex));
                    if (query.TryGetValue("returnUrl", out var v) && !string.IsNullOrWhiteSpace(v))
                    {
                        var val = v.ToString();
                        // 排除 login 自身和无效值
                        if (val is not ("login" or "not-found" or "/login"))
                            target = val.StartsWith('/') ? val : "/" + val;
                    }
                }
                // forceLoad 整页加载：新 circuit 重建后从 ProtectedLocalStorage 读 token，
                // 预渲染阶段不可用返回匿名，circuit 建立后自动重新读取认证状态
                Navigation.NavigateTo(target, forceLoad: true);
            }
            else
            {
                _error = "用户名或密码错误";
            }
        }
        catch (Exception ex)
        {
            _error = $"登录异常：{ex.Message}";
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await LoginAsync();
    }
}
