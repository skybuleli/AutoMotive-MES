@page "/production"
@attribute [StreamRendering]
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using MesAdmin.Web.Services
@inject MesApiClient Api
@inject NavigationManager Navigation

<PageTitle>生产工单 - AutoMES</PageTitle>

<MudStack Spacing="3" Class="production-page">
    <MudPaper Class="production-toolbar pa-5">
        <MudStack Row Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap" Spacing="2">
            <MudStack Spacing="1">
                <MudText Typo="Typo.overline" Class="section-kicker">M01 · Production Order</MudText>
                <MudText Typo="Typo.h4">生产工单</MudText>
            </MudStack>
            <MudStack Row Spacing="2" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
                <MudSelect T="string" Label="状态" Variant="Variant.Outlined" Dense
                           Value="@_statusFilterText" ValueChanged="OnStatusFilterChanged" Class="filter-select">
                    <MudSelectItem Value="@("all")">全部</MudSelectItem>
                    <MudSelectItem Value="@("Created")">已创建</MudSelectItem>
                    <MudSelectItem Value="@("Released")">已放行</MudSelectItem>
                    <MudSelectItem Value="@("InProgress")">执行中</MudSelectItem>
                   <MudSelectItem Value="@("Completed")">已完工</MudSelectItem>
                   <MudSelectItem Value="@("Closed")">已关闭</MudSelectItem>
                   <MudSelectItem Value="@("Cancelled")">已取消</MudSelectItem>
                </MudSelect>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="ReloadAsync" Disabled="@_busy">刷新</MudButton>
            </MudStack>
        </MudStack>
    </MudPaper>

    @if (!string.IsNullOrWhiteSpace(_message))
    {
        <MudAlert Severity="@(_isError ? Severity.Error : Severity.Success)" Variant="Variant.Filled" Dense>
            @_message
        </MudAlert>
    }

    <MudGrid Spacing="3">
        <MudItem xs="12" lg="8">
            <MudPaper Class="module-card order-list-card pa-5">
                <MudStack Spacing="3">
                    <MudStack Row Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.h6">工单列表</MudText>
                            <MudText Typo="Typo.caption" Class="section-copy">每页 10 条 · @GetFilterLabel()</MudText>
                        </MudStack>
                        <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small">
                            共 @_totalOrders 条
                        </MudChip>
                    </MudStack>

                    @if (_loadError is not null)
                    {
                        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Dense>@_loadError</MudAlert>
                    }

                    <MudTable T="OrderSummary" Dense Hover Breakpoint="Breakpoint.Sm" Items="@_pageOrders" RowsPerPage="@PageSize" Class="orders-table">
                        <HeaderContent>
                            <MudTh>工单号</MudTh>
                            <MudTh>状态</MudTh>
                            <MudTh>计划数量</MudTh>
                            <MudTh>创建时间</MudTh>
                            <MudTh>操作</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="工单号">
                                <MudButton Variant="Variant.Text" Color="Color.Primary" Class="order-number px-0" OnClick="@(() => SelectOrder(context))">
                                    @context.OrderNumber
                                </MudButton>
                            </MudTd>
                            <MudTd DataLabel="状态">
                                <MudChip T="string" Value="@context.Status" Color="@GetStatusColor(context.Status)" Variant="Variant.Filled" Size="Size.Small">
                                    @GetStatusLabel(context.Status)
                                </MudChip>
                            </MudTd>
                            <MudTd DataLabel="计划">@context.PlannedQuantity</MudTd>
                            <MudTd DataLabel="创建时间">@context.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</MudTd>
                            <MudTd DataLabel="操作">
                                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small" OnClick="@(() => SelectOrder(context))">
                                    查看
                                </MudButton>
                            </MudTd>
                        </RowTemplate>
                        <NoRecordsContent>
                            <MudText Typo="Typo.body2" Class="empty-copy">当前筛选下暂无工单。</MudText>
                        </NoRecordsContent>
                    </MudTable>

                    <div class="pager-strip">
                        <MudText Typo="Typo.body2" Class="section-copy">
                            第 @_page / @_totalPages 页 · 每页 @PageSize 条
                        </MudText>
                        <MudStack Row Spacing="1">
                            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                                       Disabled="@(_busy || _page <= 1)" OnClick="PreviousPageAsync">上一页</MudButton>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                       Disabled="@(_busy || _page >= _totalPages)" OnClick="NextPageAsync">下一页</MudButton>
                        </MudStack>
                    </div>
                </MudStack>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" lg="4">
            <MudPaper Class="module-card pa-5">
                <MudStack Spacing="3">
                    <MudText Typo="Typo.h6">创建工单</MudText>

                    <MudSelect T="string" Label="产品编码" Variant="Variant.Outlined" Dense @bind-Value="_productCode">
                        <MudSelectItem Value="@("ESP-9.0")">ESP-9.0</MudSelectItem>
                        <MudSelectItem Value="@("ESP-9.1")">ESP-9.1</MudSelectItem>
                    </MudSelect>
                    <MudTextField @bind-Value="_bomVersion" Label="BOM 版本" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    <MudNumericField T="int" @bind-Value="_plannedQuantity" Label="计划数量" Variant="Variant.Outlined" Min="1" Margin="Margin.Dense" />
                    <MudSelect T="string" Label="工艺路线" Variant="Variant.Outlined" Dense @bind-Value="_routingId">
                        @foreach (var option in RoutingOptions)
                        {
                            <MudSelectItem Value="@option.Id">@option.Name</MudSelectItem>
                        }
                    </MudSelect>
                    <MudNumericField T="short" @bind-Value="_priority" Label="优先级" Variant="Variant.Outlined" Min="1" Max="2" Margin="Margin.Dense" />

                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" FullWidth Disabled="@_busy" OnClick="CreateAsync">
                        创建工单
                    </MudButton>
                </MudStack>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudDialog @bind-Visible="_detailDialogOpen" ContentClass="order-dialog-content" ActionsClass="order-dialog-actions">
        <TitleContent>
            <MudStack Row Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap" Spacing="2">
                <MudStack Spacing="0">
                    <MudText Typo="Typo.overline" Class="section-kicker">工单详情</MudText>
                    <MudText Typo="Typo.h6">@(_selected?.OrderNumber ?? "未选择")</MudText>
                </MudStack>
                @if (_selected is not null)
                {
                    <MudChip T="string" Value="@_selected.Status" Color="@GetStatusColor(_selected.Status)" Variant="Variant.Filled" Size="Size.Small">
                        @GetStatusLabel(_selected.Status)
                    </MudChip>
                }
            </MudStack>
        </TitleContent>
        <DialogContent>
            @if (_selected is not null)
            {
                <MudGrid Spacing="2">
                    <MudItem xs="12" sm="6"><div class="detail-item"><span class="detail-label">产品</span><strong>@_selected.ProductCode</strong></div></MudItem>
                    <MudItem xs="12" sm="6"><div class="detail-item"><span class="detail-label">BOM 版本</span><strong>@_selected.BomVersion</strong></div></MudItem>
                    <MudItem xs="12"><div class="detail-item"><span class="detail-label">工艺路线</span><strong>@GetRoutingName(_selected.RoutingId)</strong></div></MudItem>
                    <MudItem xs="6" sm="4"><div class="detail-item"><span class="detail-label">计划</span><strong>@_selected.PlannedQuantity</strong></div></MudItem>
                    <MudItem xs="6" sm="4"><div class="detail-item"><span class="detail-label">良品</span><strong>@_selected.QualifiedQuantity</strong></div></MudItem>
                    <MudItem xs="6" sm="4"><div class="detail-item"><span class="detail-label">不良</span><strong>@_selected.DefectiveQuantity</strong></div></MudItem>
                    <MudItem xs="12" sm="6"><div class="detail-item"><span class="detail-label">创建时间</span><strong>@_selected.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</strong></div></MudItem>
                    <MudItem xs="12" sm="6"><div class="detail-item"><span class="detail-label">完工时间</span><strong>@(_selected.CompletedAt?.ToLocalTime().ToString("yyyy-MM-dd HH:mm") ?? "-")</strong></div></MudItem>
                </MudGrid>

                <MudDivider Class="my-4" />

                <MudGrid Spacing="2">
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="int" @bind-Value="_completeQualified" Label="良品数量" Variant="Variant.Outlined" Min="0" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="int" @bind-Value="_completeDefective" Label="不良数量" Variant="Variant.Outlined" Min="0" Margin="Margin.Dense" />
                    </MudItem>
                </MudGrid>
            }
        </DialogContent>
        <DialogActions>
            <MudButton Variant="Variant.Text" OnClick="CloseDetailDialog">关闭</MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Info" Disabled="@(!CanRelease || _busy)" OnClick="ReleaseAsync">放行</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@(!CanStart || _busy)" OnClick="StartAsync">开工</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Success" Disabled="@(!CanComplete || _busy)" OnClick="CompleteAsync">完工</MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Warning" Disabled="@(!CanClose || _busy)" OnClick="CloseAsync">关闭工单</MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Error" Disabled="@(!CanCancel || _busy)" OnClick="OpenCancelDialog">取消工单</MudButton>
        </DialogActions>
    </MudDialog>

    <MudDialog @bind-Visible="_cancelDialogOpen">
        <TitleContent>
            <MudText Typo="Typo.h6">取消工单</MudText>
        </TitleContent>
        <DialogContent>
            <MudText Typo="Typo.body2" Class="mb-3">
                确认取消工单 @(_selected?.OrderNumber)？取消后不可恢复。
            </MudText>
            <MudTextField @bind-Value="_cancelReason" Label="取消原因" Variant="Variant.Outlined"
                          Lines="2" MaxLength="256" Immediate="true" Placeholder="请填写取消原因（必填）" />
        </DialogContent>
        <DialogActions>
            <MudButton Variant="Variant.Text" OnClick="@(() => _cancelDialogOpen = false)">返回</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Error"
                       Disabled="@(_busy || string.IsNullOrWhiteSpace(_cancelReason))" OnClick="CancelAsync">确认取消</MudButton>
        </DialogActions>
    </MudDialog>
</MudStack>

@code {
    private const int PageSize = 10;

    private static readonly IReadOnlyList<RoutingOption> RoutingOptions =
    [
        new("01K25YQ2Y0Q0D8Z6EHKR1R4T3A", "前桥 ESP 总成主线"),
        new("01K25YQ2Y0Y1HDQYJ0KQ6K8V7M", "后桥 ESP 总成主线"),
        new("01K25YQ2Y0X2A9MJQPHH97M2C4", "返修与复判路线")
    ];

    private List<OrderSummary> _pageOrders = [];
    private OrderSummary? _selected;
    private OrderDetail? _selectedDetail;
    private string _productCode = "ESP-9.0";
    private string _bomVersion = "BOM-202607";
    private string _routingId = RoutingOptions[0].Id;
    private int _plannedQuantity = 500;
    private short _priority = 1;
    private int _completeQualified;
    private int _completeDefective;
    private string _statusFilterText = "all";
    private string _message = string.Empty;
    private string? _loadError;
    private bool _isError;
    private bool _busy;
    private bool _detailDialogOpen;
    private bool _cancelDialogOpen;
    private string _cancelReason = string.Empty;
    private bool _loadedOnce;
    private int _page = 1;
    private int _totalOrders;
    private int _totalPages = 1;

    private bool CanRelease => _selectedDetail?.CanRelease ?? false;
    private bool CanStart => _selectedDetail?.CanStart ?? false;
    private bool CanComplete => _selectedDetail?.CanComplete ?? false;
    private bool CanClose => _selectedDetail?.CanClose ?? false;
    private bool CanCancel => _selectedDetail?.CanCancel ?? false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _loadedOnce)
            return;

        _loadedOnce = true;

        try
        {
            await LoadPageAsync();
            StateHasChanged();
        }
        catch (HttpRequestException ex)
        {
            if (!await RedirectToLoginOnUnauthorizedAsync(ex))
            {
                _loadError = $"加载失败：{ex.Message}";
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            _loadError = $"加载失败：{ex.Message}";
            StateHasChanged();
        }
    }

    private async Task LoadPageAsync()
    {
        var status = _statusFilterText == "all" ? null : _statusFilterText;
        var path = status is null
            ? $"api/v1/orders?page={_page}&size={PageSize}"
            : $"api/v1/orders?status={status}&page={_page}&size={PageSize}";
        var (items, total) = await Api.GetWithTotalAsync<List<OrderSummary>>(path);
        _pageOrders = items ?? [];
        _totalOrders = total ?? _pageOrders.Count;
        _totalPages = Math.Max(1, (int)Math.Ceiling(_totalOrders / (double)PageSize));
        if (_page > _totalPages)
        {
            _page = _totalPages;
            await LoadPageAsync();
            return;
        }
        _loadError = null;
    }

    private async Task ReloadAsync()
    {
        try { await LoadPageAsync(); StateHasChanged(); }
        catch (HttpRequestException ex)
        {
            if (!await RedirectToLoginOnUnauthorizedAsync(ex))
                _loadError = $"刷新失败：{ex.Message}";
        }
        catch (Exception ex) { _loadError = $"刷新失败：{ex.Message}"; }
    }

    private async Task OnStatusFilterChanged(string value)
    {
        _statusFilterText = value;
        _page = 1;
        _selected = null;
        _selectedDetail = null;
        await ReloadAsync();
    }

    private async Task PreviousPageAsync()
    {
        if (_page <= 1) return;
        _page--;
        await ReloadAsync();
    }

    private async Task NextPageAsync()
    {
        if (_page >= _totalPages) return;
        _page++;
        await ReloadAsync();
    }

    private async Task SelectOrder(OrderSummary order)
    {
        _selected = order;
        _detailDialogOpen = true;
        _completeQualified = order.QualifiedQuantity;
        _completeDefective = order.DefectiveQuantity;
        try
        {
            _selectedDetail = await Api.GetAsync<OrderDetail>($"api/v1/orders/{order.Id}");
        }
        catch (HttpRequestException ex)
        {
            if (!await RedirectToLoginOnUnauthorizedAsync(ex))
                _selectedDetail = null;
        }
        catch { _selectedDetail = null; }
    }

    private void CloseDetailDialog() => _detailDialogOpen = false;

    private async Task CreateAsync()
    {
        await RunBusyAsync(async () =>
        {
            var body = new CreateOrderBody(_productCode, _bomVersion, _routingId, _plannedQuantity, _priority);
            var (ok, data, status) = await Api.PostAsync<OrderSummary>("api/v1/orders", body);
            if (!ok)
                throw new InvalidOperationException($"创建失败 (HTTP {status})");

            _selected = data;
            _message = $"已创建工单 {data!.OrderNumber}";
            _isError = false;
            await ReloadAsync();
            if (_selected is not null)
                await SelectOrder(_selected);
        });
    }

    private async Task ReleaseAsync() => await MutateSelectedAsync("released", "api/v1/orders/{id}/status", new ChangeStatusBody("Released"));
    private async Task StartAsync() => await MutateSelectedAsync("inprogress", "api/v1/orders/{id}/start");
    private async Task CompleteAsync() => await MutateSelectedPost("api/v1/orders/{id}/complete", new CompleteOrderBody(_completeQualified, _completeDefective));
    private async Task CloseAsync() => await MutateSelectedPost("api/v1/orders/{id}/close");

    private void OpenCancelDialog()
    {
        _cancelReason = string.Empty;
        _cancelDialogOpen = true;
    }

    private async Task CancelAsync()
    {
        if (string.IsNullOrWhiteSpace(_cancelReason)) return;
        await MutateSelectedPost("api/v1/orders/{id}/cancel", new CancelOrderBody(_cancelReason.Trim()));
        _cancelDialogOpen = false;
    }

    private async Task MutateSelectedAsync(string expected, string template, object? body = null)
    {
        if (_selected is null) return;
        var path = template.Replace("{id}", _selected.Id);
        await RunBusyAsync(async () =>
        {
            var (ok, data, status) = body is null
                ? await Api.PostAsync<OrderDetail>(path, new { })
                : await Api.PatchAsync<OrderDetail>(path, body);
            if (!ok) throw new InvalidOperationException($"操作失败 (HTTP {status})");
            if (data is not null) { _selectedDetail = data; _selected = data.Order; }
            _message = $"工单 {_selected!.OrderNumber} 已更新为 {GetStatusLabel(_selected.Status)}";
            _isError = false;
            await ReloadAsync();
        });
    }

    private async Task MutateSelectedPost(string template, object? body = null)
    {
        if (_selected is null) return;
        var path = template.Replace("{id}", _selected.Id);
        await RunBusyAsync(async () =>
        {
            var (ok, data, status) = body is null
                ? await Api.PostAsync<OrderDetail>(path, new { })
                : await Api.PostAsync<OrderDetail>(path, body);
            if (!ok) throw new InvalidOperationException($"操作失败 (HTTP {status})");
            if (data is not null) { _selectedDetail = data; _selected = data.Order; }
            _message = $"工单 {_selected!.OrderNumber} 已更新为 {GetStatusLabel(_selected.Status)}";
            _isError = false;
            await ReloadAsync();
        });
    }

    private async Task RunBusyAsync(Func<Task> action)
    {
        try { _busy = true; _message = string.Empty; await action(); }
        catch (HttpRequestException ex)
        {
            if (!await RedirectToLoginOnUnauthorizedAsync(ex))
            {
                _message = ex.Message;
                _isError = true;
            }
        }
        catch (Exception ex) { _message = ex.Message; _isError = true; }
        finally { _busy = false; }
    }

    private Task<bool> RedirectToLoginOnUnauthorizedAsync(HttpRequestException ex)
    {
        if (ex.StatusCode != System.Net.HttpStatusCode.Unauthorized)
            return Task.FromResult(false);

        var returnUrl = Navigation.ToBaseRelativePath(Navigation.Uri);
        Navigation.NavigateTo($"/login?returnUrl={Uri.EscapeDataString(returnUrl)}", forceLoad: true);
        return Task.FromResult(true);
    }

    private string GetRoutingName(string routingId)
        => RoutingOptions.FirstOrDefault(o => o.Id == routingId)?.Name ?? routingId;

    private string GetFilterLabel() => _statusFilterText == "all" ? "全部工单" : GetStatusLabel(_statusFilterText);

    private static string GetStatusLabel(string status) => status switch
    {
        "Created" => "已创建", "Released" => "已放行", "InProgress" => "执行中",
        "Completed" => "已完工", "Closed" => "已关闭", "Cancelled" => "已取消", _ => status
    };

    private static Color GetStatusColor(string status) => status switch
    {
        "Created" => Color.Default, "Released" => Color.Info, "InProgress" => Color.Primary,
        "Completed" => Color.Success, "Closed" => Color.Dark, "Cancelled" => Color.Error, _ => Color.Default
    };

    private sealed record RoutingOption(string Id, string Name);
}
