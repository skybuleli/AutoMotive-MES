    private static string GetBatchStatusLabel(string status) => status switch
    {
        "Received" => "已入库",
        "Qualified" => "检验合格",
        "Rejected" => "不合格",
        "Consumed" => "已消耗",
        _ => status
    };

    private static Color GetBatchStatusColor(string status) => status switch
    {
        "Received" => Color.Default,
        "Qualified" => Color.Success,
        "Rejected" => Color.Error,
        "Consumed" => Color.Warning,
        _ => Color.Default
    };

    private static Color GetRemainingColor(MaterialBatchDto batch)
        => batch.RemainingQuantity <= 0 ? Color.Warning
            : batch.IsCritical && batch.RemainingQuantity < batch.ReceivedQuantity * 0.1 ? Color.Error
            : Color.Default;



