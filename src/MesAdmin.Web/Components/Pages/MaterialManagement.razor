@page "/material"
@attribute [StreamRendering]
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using System.Net.Http.Json
@using MesAdmin.Web.Services
@inject IHttpClientFactory HttpFactory
@inject AuthService Auth
@inject NavigationManager Navigation

<PageTitle>物料管理 - AutoMES</PageTitle>

<MudStack Spacing="3" Class="oee-page">
    @* ── 工具栏 ── *@
    <MudPaper Class="oee-toolbar pa-5">
        <MudStack Row Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap" Spacing="2">
            <MudStack Spacing="1">
                <MudText Typo="Typo.overline" Class="section-kicker">T1.12 - T1.18 · Material Management</MudText>
                <MudText Typo="Typo.h4">物料管理</MudText>
                <MudText Typo="Typo.body2" Class="section-copy">来料入库 → 批次管理 → 投料绑定 · 全链路物料追踪</MudText>
            </MudStack>
            <MudStack Row Spacing="2" AlignItems="AlignItems.Center">
                <MudChip T="string" Color="Color.Success" Size="Size.Small" Variant="Variant.Outlined">
                    批次 @_totalBatches
                </MudChip>
                <MudIconButton Icon="@Icons.Material.Filled.Refresh" Disabled="@_isLoading"
                               OnClick="() => LoadBatchesAsync()" Size="Size.Small" />
            </MudStack>
        </MudStack>
    </MudPaper>

    @if (!string.IsNullOrWhiteSpace(_message))
    {
        <MudAlert Severity="@(_isError ? Severity.Error : Severity.Success)" Variant="Variant.Filled" Dense>
            @_message
        </MudAlert>
    }

    @* ── 标签页 ── *@
    <MudTabs @bind-ActivePanelIndex="_activeTab" Class="material-tabs" Centered="false" Position="Position.Top">
        @* ═══════════════════════════════════════════
           Tab 1: 批次管理
           ═══════════════════════════════════════════ *@
        <MudTabPanel Text="批次管理" Icon="@Icons.Material.Filled.Inventory2">
            <MudPaper Class="glass-kpi-card pa-4" Style="margin-top:12px;">
                <MudStack Spacing="3">
                    @* 筛选行 *@
                    <MudStack Row Spacing="2" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
                        <MudTextField @bind-Value="_batchFilter" Label="物料编码筛选"
                                      Variant="Variant.Outlined" Margin="Margin.Dense" Immediate
                                      OnKeyDown="OnBatchFilterKeyDown" Style="min-width:200px;" />
                        <MudSelect T="string" Label="状态" Variant="Variant.Outlined" Dense
                                   @bind-Value="_statusFilter" Style="min-width:120px;">
                            <MudSelectItem Value="@("all")">全部</MudSelectItem>
                            <MudSelectItem Value="@("Received")">已入库</MudSelectItem>
                            <MudSelectItem Value="@("Qualified")">检验合格</MudSelectItem>
                            <MudSelectItem Value="@("Rejected")">不合格隔离</MudSelectItem>
                            <MudSelectItem Value="@("Consumed")">已消耗完</MudSelectItem>
                        </MudSelect>
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                                  Disabled="@_isLoading" OnClick="SearchBatches">
                            <MudIcon Icon="@Icons.Material.Filled.Search" Size="Size.Small" /> 查询
                        </MudButton>
                        <MudButton Variant="Variant.Text" Color="Color.Default" Size="Size.Small"
                                  OnClick="ResetBatchFilter">重置</MudButton>
                    </MudStack>

                    @* 批次表格 *@
                    @if (_isLoading && _batches is null)
                    {
                        <MudStack AlignItems="AlignItems.Center" Spacing="2" Class="pa-4">
                            <MudProgressCircular Size="Size.Large" Color="Color.Primary" />
                            <MudText Typo="Typo.body2" Class="section-copy">加载批次数据...</MudText>
                        </MudStack>
                    }
                    else if (_batches is not null && _batches.Count == 0)
                    {
                        <MudStack AlignItems="AlignItems.Center" Spacing="2" Class="pa-6">
                            <MudIcon Icon="@Icons.Material.Filled.Inventory2" Size="Size.Large" Color="Color.Primary" />
                            <MudText Typo="Typo.body1">暂无物料批次</MudText>
                            <MudText Typo="Typo.body2" Class="section-copy">请切换到「来料入库」标签页扫码入库。</MudText>
                        </MudStack>
                    }
                    else if (_batches is not null)
                    {
                        <MudTable Items="@_batches" Dense Hover Breakpoint="Breakpoint.Sm" Class="batch-table">
                            <ColGroup>
                                <col style="width:130px" />
                                <col style="min-width:100px" />
                                <col style="width:90px" />
                                <col style="width:100px" />
                                <col style="width:80px" />
                                <col style="width:80px" />
                                <col style="width:90px" />
                                <col style="width:140px" />
                                <col style="width:130px" />
                            </ColGroup>
                            <HeaderContent>
                                <MudTh>物料编码</MudTh>
                                <MudTh>物料名称</MudTh>
                                <MudTh>批次号</MudTh>
                                <MudTh>供应商</MudTh>
                                <MudTh>入库量</MudTh>
                                <MudTh>余量</MudTh>
                                <MudTh>状态</MudTh>
                                <MudTh>生产日期</MudTh>
                                <MudTh>操作</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="物料编码">
                                    <MudStack Row Spacing="1" AlignItems="AlignItems.Center">
                                        <MudText Typo="Typo.body2" Style="font-weight:600;">@context.MaterialCode</MudText>
                                        @if (context.IsCritical)
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Outlined">关键</MudChip>
                                        }
                                    </MudStack>
                                </MudTd>
                                <MudTd DataLabel="物料名称">@context.MaterialName</MudTd>
                                <MudTd DataLabel="批次号">
                                    <MudText Typo="Typo.body2" Class="batch-number">@context.BatchNumber</MudText>
                                </MudTd>
                                <MudTd DataLabel="供应商">
                                    <MudText Typo="Typo.caption">@context.SupplierCode</MudText>
                                    <MudText Typo="Typo.caption" Class="kpi-sub">@context.SupplierName</MudText>
                                </MudTd>
                                <MudTd DataLabel="入库量">@context.ReceivedQuantity.ToString("F0")</MudTd>
                                <MudTd DataLabel="余量">
                                    <MudText Typo="Typo.body2" Color="@GetRemainingColor(context)">
                                        @context.RemainingQuantity.ToString("F0")
                                    </MudText>
                                </MudTd>
                                <MudTd DataLabel="状态">
                                    <MudChip T="string" Size="Size.Small"
                                             Color="@GetBatchStatusColor(context.Status)"
                                             Variant="Variant.Outlined">
                                        @GetBatchStatusLabel(context.Status)
                                    </MudChip>
                                </MudTd>
                                <MudTd DataLabel="生产日期">
                                    @(context.ProductionDate?.ToString("yyyy-MM-dd") ?? "-")
                                </MudTd>
                                <MudTd DataLabel="操作">
                                    @if (context.Status == "Received")
                                    {
                                        <MudButton Variant="Variant.Outlined" Color="Color.Success" Size="Size.Small"
                                                   OnClick="() => OpenQualifyDialog(context)">
                                            <MudIcon Icon="@Icons.Material.Filled.Verified" Size="Size.Small" /> 合格
                                        </MudButton>
                                        <MudButton Variant="Variant.Text" Color="Color.Error" Size="Size.Small"
                                                   OnClick="() => OpenRejectDialog(context)">
                                            拒收
                                        </MudButton>
                                    }
                                </MudTd>
                            </RowTemplate>
                            <NoRecordsContent>
                                <MudText Typo="Typo.body2" Class="empty-copy">当前筛选下无批次记录。</MudText>
                            </NoRecordsContent>
                        </MudTable>

                        @* 分页 *@
                        <MudStack Row Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
                            <MudText Typo="Typo.caption" Class="section-copy">
                                第 @_batchPage 页 · 每页 @BatchPageSize 条 · 共 @_totalBatches 条
                            </MudText>
                            <MudStack Row Spacing="1">
                                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                                           Disabled="@(_isLoading || _batchPage <= 1)"
                                           OnClick="PreviousBatchPage">上一页</MudButton>
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                           Disabled="@(_isLoading || _batches.Count < BatchPageSize)"
                                           OnClick="NextBatchPage">下一页</MudButton>
                            </MudStack>
                        </MudStack>
                    }
                </MudStack>
            </MudPaper>
        </MudTabPanel>

        @* ═══════════════════════════════════════════
           Tab 2: 来料入库（GS1-128扫码）
           ═══════════════════════════════════════════ *@
        <MudTabPanel Text="来料入库" Icon="@Icons.Material.Filled.QrCodeScanner">
            <MudPaper Class="glass-kpi-card pa-4" Style="margin-top:12px;">
                <MudStack Spacing="3">
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.subtitle1" Class="section-kicker">
                            <MudIcon Icon="@Icons.Material.Filled.QrCodeScanner" Size="Size.Small" /> GS1-128 条码入库
                        </MudText>
                        <MudText Typo="Typo.body2" Class="section-copy">
                            支持格式：(01)物料编码14位(10)批次号(11)生产日期YYMMDD(37)数量
                        </MudText>
                    </MudStack>

                    <MudGrid Spacing="3">
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="_receive.Barcode" Label="GS1-128 条码"
                                          Variant="Variant.Outlined" Margin="Margin.Dense"
                                          Placeholder="(01)12345678901234(10)BATCH001(37)500"
                                          Immediate OnKeyDown="OnReceiveBarcodeKeyDown"
                                          HelperText="扫码枪自动扫描后自动解析，或手动输入" />
                        </MudItem>
                        <MudItem xs="12" md="3">
                            <MudTextField @bind-Value="_receive.SupplierCode" Label="供应商编码"
                                          Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>
                        <MudItem xs="12" md="3">
                            <MudTextField @bind-Value="_receive.SupplierName" Label="供应商名称"
                                          Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudTextField @bind-Value="_receive.MaterialName" Label="物料名称"
                                          Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudTextField @bind-Value="_parsedMaterialCode" Label="物料编码（条码解析）"
                                          Variant="Variant.Outlined" Margin="Margin.Dense"
                                          Disabled="@true" HelperText="从 GS1-128 条码自动提取" />
                        </MudItem>
                        <MudItem xs="6" md="2">
                            <MudTextField @bind-Value="_parsedQuantity" Label="数量（条码解析）"
                                          Variant="Variant.Outlined" Margin="Margin.Dense"
                                          Disabled="@true" InputType="InputType.Number" />
                        </MudItem>
                        <MudItem xs="6" md="2">
                            <MudSwitch @bind-Value="_receive.IsCritical" Color="Color.Error"
                                       Label="关键物料" />
                        </MudItem>
                    </MudGrid>

                    <MudStack Row Spacing="2" Justify="Justify.FlexEnd">
                        <MudButton Variant="Variant.Text" Color="Color.Default"
                                   OnClick="ClearReceiveForm">清空</MudButton>
                        <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Large"
                                   Disabled="@(_isReceiving || string.IsNullOrWhiteSpace(_receive.Barcode))"
                                   OnClick="ReceiveMaterialAsync">
                            <MudIcon Icon="@Icons.Material.Filled.Save" Size="Size.Small" /> 入库确认
                        </MudButton>
                    </MudStack>

                    @if (_receiveResult is not null)
                    {
                        <MudPaper Class="pa-4" Style="background: rgba(76,175,80,0.08); border:1px solid rgba(76,175,80,0.3); border-radius:12px;">
                            <MudStack Spacing="1">
                                <MudStack Row AlignItems="AlignItems.Center" Spacing="1">
                                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                                    <MudText Typo="Typo.subtitle2" Color="Color.Success">入库成功</MudText>
                                </MudStack>
                                <MudText Typo="Typo.body2">
                                    批次 @_receiveResult.BatchNumber · 物料 @_receiveResult.MaterialCode
                                    · 数量 @_receiveResult.ReceivedQuantity.ToString("F0") @_receiveResult.Unit
                                </MudText>
                            </MudStack>
                        </MudPaper>
                    }
                </MudStack>
            </MudPaper>
        </MudTabPanel>

        @* ═══════════════════════════════════════════
           Tab 3: 投料绑定
           ═══════════════════════════════════════════ *@
        <MudTabPanel Text="投料绑定" Icon="@Icons.Material.Filled.Link">
            <MudPaper Class="glass-kpi-card pa-4" Style="margin-top:12px;">
                <MudStack Spacing="3">
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.subtitle1" Class="section-kicker">
                            <MudIcon Icon="@Icons.Material.Filled.Link" Size="Size.Small" /> 投料批次绑定
                        </MudText>
                        <MudText Typo="Typo.body2" Class="section-copy">
                            物料批次 → 工单 → 产品 S/N · Poka-Yoke 防错自动校验
                        </MudText>
                    </MudStack>

                    <MudGrid Spacing="3">
                        <MudItem xs="12" md="4">
                            <MudTextField @bind-Value="_bind.OrderId" Label="工单 Id"
                                          Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudTextField @bind-Value="_bind.MaterialBatchId" Label="物料批次 Id"
                                          Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudTextField @bind-Value="_bind.ProductSerial" Label="产品序列号（S/N）"
                                          Variant="Variant.Outlined" Margin="Margin.Dense"
                                          Placeholder="ESP9-20260705-0001" />
                        </MudItem>
                        <MudItem xs="6" md="3">
                            <MudNumericField T="double" @bind-Value="_bind.Quantity" Label="投料数量"
                                             Variant="Variant.Outlined" Margin="Margin.Dense" Min="1" />
                        </MudItem>
                        <MudItem xs="6" md="3">
                            <MudTextField @bind-Value="_bind.OperatorId" Label="操作员工号"
                                          Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
                                       FullWidth Disabled="@(_isBinding || !IsBindFormValid)"
                                       OnClick="BindMaterialAsync">
                                <MudIcon Icon="@Icons.Material.Filled.Link" Size="Size.Small" /> 执行绑定
                            </MudButton>
                        </MudItem>
                    </MudGrid>

                    @if (_bindResult is not null)
                    {
                        <MudPaper Class="pa-4" Style="@GetBindResultStyle()">
                            <MudStack Spacing="1">
                                <MudStack Row AlignItems="AlignItems.Center" Spacing="1">
                                    <MudIcon Icon="@(_bindResult.PokaYokePassed ? Icons.Material.Filled.Verified : Icons.Material.Filled.Error)" 
                                             Color="@(_bindResult.PokaYokePassed ? Color.Success : Color.Error)" Size="Size.Small" />
                                    <MudText Typo="Typo.subtitle2" Color="@(_bindResult.PokaYokePassed ? Color.Success : Color.Error)">
                                        @(_bindResult.PokaYokePassed ? "Poka-Yoke ✅ 绑定成功" : "Poka-Yoke ❌ 校验失败")
                                    </MudText>
                                </MudStack>
                                <MudText Typo="Typo.body2">
                                    物料 @_bindResult.MaterialCode · 批次 @_bindResult.BatchNumber
                                     → 产品 @_bindResult.ProductSerial
                                </MudText>
                            </MudStack>
                        </MudPaper>
                    }

                    @* 快速参考：最近绑定记录 *@
                    <MudText Typo="Typo.subtitle2" Class="section-kicker" Style="margin-top:8px;">
                        <MudIcon Icon="@Icons.Material.Filled.History" Size="Size.Small" /> 最近绑定记录
                    </MudText>
                    @if (_recentBindings is not null && _recentBindings.Count > 0)
                    {
                        <MudTable Items="@_recentBindings" Dense Hover Breakpoint="Breakpoint.Sm">
                            <ColGroup>
                                <col style="width:100px" />
                                <col style="width:100px" />
                                <col style="width:130px" />
                                <col style="width:60px" />
                                <col style="width:70px" />
                                <col style="width:100px" />
                                <col />
                            </ColGroup>
                            <HeaderContent>
                                <MudTh>物料编码</MudTh>
                                <MudTh>批次号</MudTh>
                                <MudTh>产品序列号</MudTh>
                                <MudTh>数量</MudTh>
                                <MudTh>防错</MudTh>
                                <MudTh>操作人</MudTh>
                                <MudTh>时间</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="物料编码">@context.MaterialCode</MudTd>
                                <MudTd DataLabel="批次号">@context.BatchNumber</MudTd>
                                <MudTd DataLabel="产品序列号">@context.ProductSerial</MudTd>
                                <MudTd DataLabel="数量">@context.Quantity.ToString("F0")</MudTd>
                                <MudTd DataLabel="防错">
                                    <MudChip T="string" Size="Size.Small"
                                             Color="@(context.PokaYokePassed ? Color.Success : Color.Error)"
                                             Variant="Variant.Outlined">
                                        @(context.PokaYokePassed ? "OK" : "NG")
                                    </MudChip>
                                </MudTd>
                                <MudTd DataLabel="操作人">@context.OperatorId</MudTd>
                                <MudTd DataLabel="时间">@context.BoundAt.ToLocalTime().ToString("MM-dd HH:mm")</MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Class="section-copy">暂无绑定记录。</MudText>
                    }
                </MudStack>
            </MudPaper>
        </MudTabPanel>
    </MudTabs>
</MudStack>

@* ── 质检合格确认对话框 ── *@
<MudDialog @bind-Visible="_qualifyDialogVisible">
    <DialogContent>
        <MudStack Spacing="2">
            <MudText Typo="Typo.subtitle1">批次检验合格</MudText>
            <MudText Typo="Typo.body2">物料：@(_selectedBatch?.MaterialCode) @(_selectedBatch?.MaterialName)</MudText>
            <MudText Typo="Typo.body2">批次：@(_selectedBatch?.BatchNumber)</MudText>
            <MudText Typo="Typo.body2">数量：@(_selectedBatch?.ReceivedQuantity.ToString("F0")) @(_selectedBatch?.Unit)</MudText>
            <MudTextField @bind-Value="_batchOperator" Label="质检员工号"
                          Variant="Variant.Outlined" Margin="Margin.Dense" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="() => _qualifyDialogVisible = false">取消</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Success"
                   Disabled="string.IsNullOrWhiteSpace(_batchOperator)"
                   OnClick="QualifyBatchAsync">
            <MudIcon Icon="@Icons.Material.Filled.Verified" /> 确认合格
        </MudButton>
    </DialogActions>
</MudDialog>

@* ── 拒收确认对话框 ── *@
<MudDialog @bind-Visible="_rejectDialogVisible">
    <DialogContent>
        <MudStack Spacing="2">
            <MudText Typo="Typo.subtitle1" Color="Color.Error">批次不合格（拒收）</MudText>
            <MudText Typo="Typo.body2">物料：@(_selectedBatch?.MaterialCode) @(_selectedBatch?.MaterialName)</MudText>
            <MudText Typo="Typo.body2">批次：@(_selectedBatch?.BatchNumber)</MudText>
            <MudTextField @bind-Value="_rejectReason" Label="不合格原因"
                          Variant="Variant.Outlined" Margin="Margin.Dense" />
            <MudTextField @bind-Value="_batchOperator" Label="质检员工号"
                          Variant="Variant.Outlined" Margin="Margin.Dense" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="() => _rejectDialogVisible = false">取消</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Error"
                   Disabled="string.IsNullOrWhiteSpace(_batchOperator) || string.IsNullOrWhiteSpace(_rejectReason)"
                   OnClick="RejectBatchAsync">
            <MudIcon Icon="@Icons.Material.Filled.Cancel" /> 确认拒收
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    private const int BatchPageSize = 15;

    // ── 通用状态 ──
    private int _activeTab;
    private bool _isLoading, _isReceiving, _isBinding;
    private string? _message;
    private bool _isError;

    // ── Tab 1: 批次管理 ──
    private List<MaterialBatchDto>? _batches;
    private string _batchFilter = string.Empty;
    private string _statusFilter = "all";
    private int _batchPage = 1;
    private int _totalBatches;
    private MaterialBatchDto? _selectedBatch;
    private bool _qualifyDialogVisible, _rejectDialogVisible;
    private string _batchOperator = string.Empty;
    private string _rejectReason = string.Empty;

    // ── Tab 2: 来料入库 ──
    private readonly ReceiveFormModel _receive = new();
    private string _parsedMaterialCode = string.Empty;
    private string _parsedQuantity = string.Empty;
    private MaterialBatchDto? _receiveResult;

    // ── Tab 3: 投料绑定 ──
    private readonly BindFormModel _bind = new();
    private MaterialBindingDto? _bindResult;
    private List<MaterialBindingDto>? _recentBindings;

    private bool IsBindFormValid =>
        !string.IsNullOrWhiteSpace(_bind.OrderId)
        && !string.IsNullOrWhiteSpace(_bind.MaterialBatchId)
        && !string.IsNullOrWhiteSpace(_bind.ProductSerial)
        && _bind.Quantity > 0
        && !string.IsNullOrWhiteSpace(_bind.OperatorId);

    // ═══════════════════════════════════════════
    // 页面初始化
    // ═══════════════════════════════════════════

    protected override async Task OnInitializedAsync()
    {
        await LoadBatchesAsync();
        await LoadRecentBindingsAsync();
    }

    private async Task<HttpClient> CreateClientAsync()
    {
        var client = HttpFactory.CreateClient("MesApi");
        var token = await Auth.GetTokenAsync();
        if (token is not null)
            client.DefaultRequestHeaders.Authorization =
                new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
        return client;
    }

    // ═══════════════════════════════════════════
    // Tab 1: 批次管理
    // ═══════════════════════════════════════════

    private async Task LoadBatchesAsync()
    {
        _isLoading = true;
        _message = null;
        try
        {
            var client = await CreateClientAsync();
            var materialCode = string.IsNullOrWhiteSpace(_batchFilter) ? null : _batchFilter;
            var status = _statusFilter == "all" ? null : _statusFilter;

            var path = $"api/v1/materials/batches?page={_batchPage}&size={BatchPageSize}";
            if (materialCode is not null)
                path += $"&materialCode={Uri.EscapeDataString(materialCode)}";

            var resp = await client.GetAsync(path);
            resp.EnsureSuccessStatusCode();

            var total = resp.Headers.TryGetValues("X-Total-Count", out var values)
                && int.TryParse(values.FirstOrDefault(), out var parsed)
                    ? parsed
                    : 0;
            _totalBatches = total;

            var items = await resp.Content.ReadFromJsonAsync<List<MaterialBatchDto>>();
            _batches = items ?? [];

            // 客户端侧状态筛选（API 不支持按状态过滤时）
            if (status is not null && _batches.Count > 0)
            {
                _batches = _batches.Where(b => b.Status == status).ToList();
            }
        }
        catch (Exception ex)
        {
            _message = $"加载批次失败：{ex.Message}";
            _isError = true;
        }
        finally
        {
            _isLoading = false;
        }
    }

